# =============================================================================
# FreightClause Tender — environment variables
# Copy to .env for local dev. In production, set these via Fly secrets and
# Cloudflare Pages environment variables (see DEPLOY.md).
# =============================================================================

# ---------------- Backend (Fly.io) ----------------
NODE_ENV=development
PORT=5000
DATABASE_PATH=./data.db

# Comma-separated list of allowed CORS origins (Cloudflare Pages URL + any
# custom domains). Leave blank in local dev to allow everything.
CORS_ORIGIN=

# Google Maps server-side key (also configurable from Settings UI — DB wins
# if both are set).
GOOGLE_MAPS_API_KEY=

# ---------------- Litestream (production only) ----------------
# S3 or Cloudflare R2 replica for SQLite. Leave blank to skip replication.
LITESTREAM_REPLICA_URL=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# ---------------- Frontend (Cloudflare Pages) ----------------
# Build-time only — must be prefixed with VITE_.
# Set this in Cloudflare Pages > Settings > Environment variables.
VITE_API_BASE=https://freightclause-tender-api.fly.dev
